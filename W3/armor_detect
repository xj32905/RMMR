    # 【关键修复】三级亮度判断与预处理
    hsv_temp = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
    avg_brightness = np.mean(hsv_temp[:,:,2])
    
    if avg_brightness > 180:  # 严重过曝
        print("[预处理] 检测到严重过曝(曝光5000),应用强CLAHE+伽马校正...")
        img = preprocess_for_bright(img, strong=True)  # 使用强模式
        save_image("preprocessed.png", img)
    elif avg_brightness > 130:  # 中等过曝
        print("[预处理] 检测到中等过曝(曝光3000),应用CLAHE增强...")
        img = preprocess_for_bright(img, strong=False)  # 使用标准模式
        save_image("preprocessed.png", img)
    else:
        print("[预处理] 低亮度环境,跳过预处理")
    
    red_mask, blue_mask = color_sep(img)
    save_image("red_raw.png", red_mask)
    save_image("blue_raw.png", blue_mask)

    red = detect(img, red_mask, "red", RED_OPEN, RED_CLOSE, RED_X_MIN, RED_X_MAX,
                 RED_AREA[0], RED_AREA[1], RED_RATIO[0], RED_RATIO[1], RED_ANGLE,
                 RED_PAIR[0], RED_PAIR[1], RED_PAIR[2], RED_PAIR[3], RED_ASPECT[0], RED_ASPECT[1])

    blue = detect(img, blue_mask, "blue", BLUE_OPEN, BLUE_CLOSE, BLUE_X_MIN, BLUE_X_MAX,
                  BLUE_AREA[0], BLUE_AREA[1], BLUE_RATIO[0], BLUE_RATIO[1], BLUE_ANGLE,
                  BLUE_PAIR[0], BLUE_PAIR[1], BLUE_PAIR[2], BLUE_PAIR[3], BLUE_ASPECT[0], BLUE_ASPECT[1],
                  BLUE_Y_MIN, BLUE_Y_MAX)

    # 【新增】去重处理
    print("\n[后处理] 开始去重...")
    red = filter_duplicate_armors(red, min_dist=30)
    blue = filter_duplicate_armors(blue, min_dist=40)

    all_armors = red + blue
    print(f"\n{'='*50}")
    print(f"完成: {len(all_armors)} 个装甲板")
    print(f"  红色: {len(red)}")
    print(f"  蓝色: {len(blue)}")
    print(f"{'='*50}\n")
    
    res = draw(img, all_armors)
    save_image("final.png", res)

    # 【修复】抑制Qt字体警告
    import warnings
    warnings.filterwarnings('ignore')
    
    cv2.imshow("red_mask", red_mask)
    cv2.imshow("blue_mask", blue_mask)
    cv2.imshow("Result", res)
    print("按任意键关闭窗口...")
    cv2.waitKey(0)
    cv2.destroyAllWindows()


if __name__ == "__main__":
